# =============================================================================
# Mary Kay Session Service — Environment Variables
# Copy this file to .env for local development.
# On Render.com, set these in the Dashboard → Environment section.
# =============================================================================

# A secret key that your Google Apps Script must send in the x-api-key header.
# Generate a strong random string, e.g.: openssl rand -hex 32
API_SECRET_KEY=replace_with_a_strong_random_secret

# ── Mary Kay Account Credentials ─────────────────────────────────────────────
# Add one block per consultant account.
# The number suffix (1, 2, 3...) just needs to be sequential.

# Account 1
MK_ACCOUNT_1_NUM=JA7516
MK_ACCOUNT_1_PASS=Wemhoff824!

# Account 2 (add more as needed)
# MK_ACCOUNT_2_NUM=JB1234
# MK_ACCOUNT_2_PASS=AnotherPassword!

# Account 3
# MK_ACCOUNT_3_NUM=JC5678
# MK_ACCOUNT_3_PASS=YetAnotherPassword!
